# Coverage scope = application code. The files below are standalone argparse
# CLI/ops scripts (manual seeding, CSV import, admin elevation) with __main__
# entry points; none are imported by routers/services/main, so they're excluded
# from the 80% gate rather than tested as app logic.
[run]
omit =
    seed.py
    import_tasks_csv.py
    elevate_admin.py
    script_utils.py
