{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/feedback/**",
              "components/filters/**",
              "components/layout/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Lora|Courier Prime|Bebas Neue|Special Elite|Share Tech Mono|Permanent Marker|Caveat|Playfair Display|Marcellus|Marcellus SC|Anton|Archivo Black|Cinzel|EB Garamond|Cormorant Garamond))/i]",
        "message": "Font not provided by the design system. Available: Lora, Courier Prime, Bebas Neue, Special Elite, Share Tech Mono, Permanent Marker, Caveat, Playfair Display, Marcellus, Marcellus SC, Anton, Archivo Black, Cinzel, EB Garamond, Cormorant Garamond."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|onClick|disabled|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, onClick, disabled, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionCommentBox'] > JSXAttribute > JSXIdentifier[name!=/^(?:faction|name|handle|meta|body|avatar|key|ref|className|style|children)$/]",
        "message": "<FactionCommentBox> doesn't accept that prop. Declared props: faction, name, handle, meta, body, avatar."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionCommentBox'] > JSXAttribute[name.name='faction'] > Literal[value!=/^(?:ua|wow|gestalt|snide|ephemerists|singularity|everymen|albescent)$/]",
        "message": "<FactionCommentBox> faction must be one of 'ua' | 'wow' | 'gestalt' | 'snide' | 'ephemerists' | 'singularity' | 'everymen' | 'albescent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionPennant'] > JSXAttribute > JSXIdentifier[name!=/^(?:slug|name|active|onClick|key|ref|className|style|children)$/]",
        "message": "<FactionPennant> doesn't accept that prop. Declared props: slug, name, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionPraxisCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:faction|task|finding|author|excerpt|rating|marks|points|level|key|ref|className|style|children)$/]",
        "message": "<FactionPraxisCard> doesn't accept that prop. Declared props: faction, task, finding, author, excerpt, rating, marks, points, level."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionPraxisCard'] > JSXAttribute[name.name='faction'] > Literal[value!=/^(?:ua|wow|gestalt|snide|ephemerists|singularity|everymen)$/]",
        "message": "<FactionPraxisCard> faction must be one of 'ua' | 'wow' | 'gestalt' | 'snide' | 'ephemerists' | 'singularity' | 'everymen'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionTaskCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:faction|title|description|level|points|onSignup|key|ref|className|style|children)$/]",
        "message": "<FactionTaskCard> doesn't accept that prop. Declared props: faction, title, description, level, points, onSignup."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionTaskCard'] > JSXAttribute[name.name='faction'] > Literal[value!=/^(?:ua|wow|gestalt|snide|ephemerists|singularity|everymen)$/]",
        "message": "<FactionTaskCard> faction must be one of 'ua' | 'wow' | 'gestalt' | 'snide' | 'ephemerists' | 'singularity' | 'everymen'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionVoteStamps'] > JSXAttribute > JSXIdentifier[name!=/^(?:faction|value|average|totalVotes|onVote|key|ref|className|style|children)$/]",
        "message": "<FactionVoteStamps> doesn't accept that prop. Declared props: faction, value, average, totalVotes, onVote."
      },
      {
        "selector": "JSXOpeningElement[name.name='FactionVoteStamps'] > JSXAttribute[name.name='faction'] > Literal[value!=/^(?:ua|gestalt|snide|ephemerists|singularity|everymen|albescent)$/]",
        "message": "<FactionVoteStamps> faction must be one of 'ua' | 'gestalt' | 'snide' | 'ephemerists' | 'singularity' | 'everymen' | 'albescent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterStamp'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|active|onClick|key|ref|className|style|children)$/]",
        "message": "<FilterStamp> doesn't accept that prop. Declared props: label, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelNodes'] > JSXAttribute > JSXIdentifier[name!=/^(?:levels|value|onChange|key|ref|className|style|children)$/]",
        "message": "<LevelNodes> doesn't accept that prop. Declared props: levels, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|factionSlug|key|ref|className|style|children)$/]",
        "message": "<LevelPill> doesn't accept that prop. Declared props: level, factionSlug."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|eyebrow|key|ref|className|style|children)$/]",
        "message": "<PageTitle> doesn't accept that prop. Declared props: title, eyebrow."
      },
      {
        "selector": "JSXOpeningElement[name.name='WatercolorBackground'] > JSXAttribute > JSXIdentifier[name!=/^(?:fixed|style|key|ref|className|style|children)$/]",
        "message": "<WatercolorBackground> doesn't accept that prop. Declared props: fixed, style."
      }
    ]
  },
