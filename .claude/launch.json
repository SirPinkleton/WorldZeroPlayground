{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--reload"],
      "port": 8000
    },
    {
      "name": "Frontend (React)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000
    },
    {
      "name": "Database (PostgreSQL via Docker)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up", "-d"],
      "port": 5432
    }
  ]
}
